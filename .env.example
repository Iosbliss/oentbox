# Django
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com
DOMAIN=your-domain.com

# Database (Postgres)
DB_HOST=db
DB_PORT=5432
DB_NAME=oentbox
DB_USER=oentbox
DB_PASSWORD=change-me-strong-db-password

# Seed database on first deploy (set to "true" then remove after first run)
SEED_DATABASE=true

# SSL (leave commented until you have certs)
# CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com